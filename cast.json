{
  "use_flake": true,
  "extra_data_volumes": {
    "cargo": {
      "source": "~/.cargo/",
      "target": "~/.cargo/",
      "type": "bind",
      "mode": "rw"
    },
    "cargo": {
      "source": "~/code/palekiwi-labs/dev-notes/cast",
      "target": "~/code/palekiwi-labs/dev-notes/cast",
      "type": "bind",
      "mode": "rw"
    }
  },
  "mcp": {
    "port": 30305,
    "hostname": "0.0.0.0",
    "tools": {
      "get_system_info": {
        "description": "Returns basic system information like kernel version and uptime",
        "command": "uname",
        "args": ["-a"],
        "parameters": {
          "type": "object",
          "properties": {}
        }
      }
    }
  }
}
