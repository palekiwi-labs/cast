{
  "use_flake": true,
  "extra_data_volumes": {
    "cargo": {
      "source": "~/.cargo/",
      "target": "~/.cargo/",
      "type": "bind",
      "mode": "rw"
    },
    "dev_notes": {
      "source": "~/code/palekiwi-labs/dev-notes/cast",
      "target": "~/code/palekiwi-labs/dev-notes/cast",
      "type": "bind",
      "mode": "rw"
    }
  },
  "mcp": {
    "port": 30305,
    "hostname": "0.0.0.0",
    "tools": {
      "get_system_info": {
        "description": "Returns basic system information like kernel version and uptime",
        "command": "uname",
        "args": ["-a"],
        "parameters": {
          "type": "object",
          "properties": {}
        }
      },
      "example_tool": {
        "description": "A comprehensive example to test MCP argument mapping",
        "command": "echo",
        "args": [
          "Base:", "{message}",
          "Items:", "{...items}"
        ],
        "parameters": {
          "type": "object",
          "properties": {
            "message": {
              "type": "string",
              "description": "The main message (Required)"
            },
            "items": {
              "type": "array",
              "items": { "type": "string" },
              "description": "A list of items to expand via spread operator"
            }
          },
          "required": ["message"]
        }
      }
    }
  }
}
